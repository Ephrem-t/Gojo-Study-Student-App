{
  "expo": {
    "name": "gojo-student-app",
    "slug": "gojo-student-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "gojostudentapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.bemni_12.gojostudentapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@config-plugins/react-native-blob-util",
      "@config-plugins/react-native-pdf",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Gojo Student App to access your photos.",
          "savePhotosPermission": "Allow Gojo Student App to save images to your gallery."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F6F8FC",
          "dark": {
            "backgroundColor": "#17212B"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "574773e5-40a7-4aaa-8b8d-113c0cba5bec"
      }
    }
  }
}
