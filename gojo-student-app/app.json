{
  "expo": {
    "name": "gojo-student-app",
    "slug": "gojo-student-app",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/app-icon.png",
    "scheme": "gojostudentapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EAF4FF",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "foregroundImage": "./assets/images/app-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.bemni_12.gojostudentapp",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.DOWNLOAD_WITHOUT_NOTIFICATION",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@config-plugins/react-native-blob-util",
      "@config-plugins/react-native-pdf",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Gojo Student App to access your photos.",
          "savePhotosPermission": "Allow Gojo Student App to save images to your gallery."
        }
      ]
    ,
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-students.png",
          "imageWidth": 1,
          "backgroundColor": "#F2F8FF",
          "dark": {
            "backgroundColor": "#07111B"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4981456b-2748-48c1-a3f9-83e382fa9168"
      }
    },
    "owner": "eramota3"
  }
}
